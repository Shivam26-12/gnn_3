 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 04 \u2014 GNN Training\n",
    "\n",
    "Train DTNetGNN (GAT) and IsolatedBaseline (MLP) on M5 data:\n",
    "- 30,490 Item-Store series\n",
    "- WRMSSE as primary metric\n",
    "- BFloat16 on A100"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import numpy as np\n",
    "import torch\n",
    "np.random.seed(42)\n",
    "torch.manual_seed(42)\n",
    "\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f'Device: {device}')\n",
    "if device.type == 'cuda':\n",
    "    print(f'GPU: {torch.cuda.get_device_name(0)}')\n",
    "    print(f'VRAM: {torch.cuda.get_device_properties(0).total_mem / 1e9:.1f} GB')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4.1 Prepare Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.data.loader import load_m5\n",
    "from src.gnn.dataset import build_dataloaders\n",
    "\n",
    "dfs = load_m5()\n",
    "\n",
    "train_loader, val_loader, test_loader = build_dataloaders(\n",
    "    sales_df=dfs['sales'],\n",
    "    calendar_df=dfs['calendar'],\n",
    "    prices_df=dfs['prices'],\n",
    "    G=None,\n",
    "    batch_size=8, stride=7\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4.2 Train Both Models"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.gnn.train import run_training\n",
    "\n",
    "gnn_hist, base_hist = run_training(train_loader, val_loader, device)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4.3 Plot Training History"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "\n",
    "axes[0].plot(gnn_hist['train_loss'], label='GNN train')\n",
    "axes[0].plot(gnn_hist['val_loss'], label='GNN val')\n",
    "axes[0].plot(base_hist['train_loss'], label='Baseline train', linestyle='--')\n",
    "axes[0].plot(base_hist['val_loss'], label='Baseline val', linestyle='--')\n",
    "axes[0].set_xlabel('Epoch')\n",
    "axes[0].set_ylabel('MSE Loss')\n",
    "axes[0].set_title('Training Loss')\n",
    "axes[0].legend()\n",
    "axes[0].grid(True, alpha=0.3)\n",
    "\n",
    "axes[1].plot(gnn_hist['val_wrmsse'], label='GNN WRMSSE')\n",
    "axes[1].plot(base_hist['val_wrmsse'], label='Baseline WRMSSE', linestyle='--')\n",
    "axes[1].set_xlabel('Epoch')\n",
    "axes[1].set_ylabel('WRMSSE')\n",
    "axes[1].set_title('Validation WRMSSE')\n",
    "axes[1].legend()\n",
    "axes[1].grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
 ],
