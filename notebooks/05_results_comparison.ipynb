 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 05 \u2014 Results Comparison\n",
    "\n",
    "Evaluate trained models on test set and generate thesis figures:\n",
    "- WRMSSE comparison (GNN vs Baseline)\n",
    "- 30,490 Item-Store series evaluation\n",
    "- Visualization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "import numpy as np\n",
    "import torch\n",
    "np.random.seed(42)\n",
    "torch.manual_seed(42)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5.1 Prepare Test Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.data.loader import load_m5\n",
    "from src.gnn.dataset import build_dataloaders\n",
    "\n",
    "dfs = load_m5()\n",
    "\n",
    "_, _, test_loader = build_dataloaders(\n",
    "    sales_df=dfs['sales'],\n",
    "    calendar_df=dfs['calendar'],\n",
    "    prices_df=dfs['prices'],\n",
    "    G=None,\n",
    "    batch_size=8, stride=7\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5.2 Evaluate on Test Set"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.gnn.evaluate import run_evaluation\n",
    "\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "results = run_evaluation(test_loader, G=None, device=device)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5.3 Generate Thesis Figures"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from src.viz.comparison_viz import generate_all_figures\n",
    "\n",
    "figures = generate_all_figures(results)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5.4 Results Summary"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('\\n=== FINAL TEST RESULTS ===')\n",
    "print(f'{\"Model\":<22} {\"MSE\":>10} {\"MAE\":>10} {\"WRMSSE\":>10}')\n",
    "print('-' * 55)\n",
    "for name, key in [('DTNetGNN', 'gnn_test'), ('IsolatedBaseline', 'baseline_test')]:\n",
    "    m = results[key]\n",
    "    print(f'{name:<22} {m[\"mse\"]:>10.6f} {m[\"mae\"]:>10.4f} {m[\"wrmsse\"]:>10.4f}')\n",
    "\n",
    "gnn_w = results['gnn_test']['wrmsse']\n",
    "base_w = results['baseline_test']['wrmsse']\n",
    "improvement = (base_w - gnn_w) / base_w * 100\n",
    "print(f'\\nGNN improvement over Baseline: {improvement:.1f}%')"
   ]
  }
 ],
